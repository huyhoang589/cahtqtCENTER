  height: 100vh;
  overflow: hidden;
  font-family: var(--font-ui);
  font-size: var(--font-size-base);
  background: var(--color-bg-window);
  color: var(--color-text-primary);
}

/* ---- Layout Shell ---- */
.app-shell {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

.app-body {
  display: flex;
  flex: 1;
  overflow: hidden;
}

.app-main-area {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow: hidden;
}

.app-content {
  flex: 1;
  overflow: auto;
  background: var(--color-bg-content);
  padding: var(--space-6);
}

/* ---- Buttons ---- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  height: 32px;
  padding: 0 20px;
  border-radius: var(--radius-md);
  font-family: var(--font-ui);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  border: none;
  cursor: pointer;
  transition: background var(--transition-base);
  white-space: nowrap;
}

.btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.btn-primary {
  background: var(--color-accent-primary);
  color: #ffffff;
}
.btn-primary:hover:not(:disabled) { background: #0097b8; }
.btn-primary:active:not(:disabled) { background: #007a96; }
.btn-primary:disabled { background: var(--color-border-dark); color: var(--color-text-label); }

.btn-success {
  background: var(--color-accent-success);
  color: #ffffff;
}
.btn-success:hover:not(:disabled) { background: #76a83e; }

.btn-danger {
  background: transparent;
  border: 1px solid var(--color-accent-danger);
  color: var(--color-accent-danger);
}
.btn-danger:hover:not(:disabled) { background: rgba(244,67,54,0.1); }

.btn-danger-filled {
  background: var(--color-accent-danger);
  color: #ffffff;
}
.btn-danger-filled:hover:not(:disabled) { background: #d32f2f; }


.btn-ghost {
  background: transparent;
  border: 1px solid var(--color-border-dark);
  color: var(--color-text-secondary);
}
.btn-ghost:hover:not(:disabled) { background: rgba(255,255,255,0.05); }

.btn-icon {
  width: 32px;
  height: 32px;
  padding: 0;
  border-radius: var(--radius-md);
  background: transparent;
  border: none;
  color: var(--color-text-secondary);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: background var(--transition-base);
}
.btn-icon:hover { background: rgba(255,255,255,0.08); }

/* Legacy button compat (used in existing pages) */
button {
  cursor: pointer;
  font-family: var(--font-ui);
  font-size: var(--font-size-base);
  border: none;
  border-radius: var(--radius-sm);
  padding: 6px 14px;
  background: var(--color-bg-surface);
  color: var(--color-text-primary);
  transition: background var(--transition-base);
}
button:hover:not(:disabled) { background: #253554; }
button:disabled { opacity: 0.45; cursor: not-allowed; }
button.primary { background: var(--color-accent-primary); color: #fff; }
button.primary:hover:not(:disabled) { background: #0097b8; }

/* ---- Inputs ---- */
input,
select {
  font-family: var(--font-ui);
  font-size: var(--font-size-base);
  height: 32px;
  background: var(--color-bg-input);
  color: var(--color-text-on-light);
  border: 1px solid var(--color-border-input);
  border-radius: var(--radius-sm);
  padding: 0 10px;
  width: 100%;
  outline: none;
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}
input:focus,
select:focus {
  border-color: var(--color-border-focus);
  box-shadow: 0 0 0 2px rgba(0,180,216,0.2);
}
input::placeholder { color: var(--color-text-secondary); }

/* ---- Tables ---- */
.table-container {
  background: var(--color-bg-table-row);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-md);
  overflow: hidden;
}

table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--font-size-base);
}

th {
  text-align: left;
  padding: 0 12px;
  height: 36px;
  background: var(--color-bg-table-header);
  color: var(--color-text-primary);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

td {
  padding: 0 12px;
  height: 36px;
  font-size: var(--font-size-base);
  color: var(--color-text-on-light);
  border-bottom: 1px solid #e2e8f0;
}

tr:nth-child(even) td { background: var(--color-bg-table-row-alt); }
tr:hover td { background: var(--color-bg-table-hover); }

.table-row-selected td {
  background: #bfdbfe;
  border-left: 3px solid var(--color-accent-primary);
}

/* ---- Dialog CSS classes (used with Radix) ---- */
.dialog-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(2px);
  z-index: 50;
}

.dialog-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 51;
  background: var(--color-bg-dialog);
  border: 1px solid var(--color-border-dark);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xl);
  min-width: 400px;
  max-width: 600px;
  width: 90vw;
}

.dialog-content-token {
  background: var(--color-bg-dialog-token);
  border-color: var(--color-border-dialog-token);
}

.dialog-header {
  padding: 20px 24px 16px;
  border-bottom: 1px solid var(--color-border-dark);
}

.dialog-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.dialog-body {
  padding: 0 24px 20px;
  padding-top: 16px;
}

.dialog-footer {
  padding: 16px 24px;
  border-top: 1px solid var(--color-border-dark);
  display: flex;
  justify-content: flex-end;
  gap: var(--space-2);
}

/* ---- Popover ---- */
.popover-content {
  background: var(--color-bg-surface);
  border: 1px solid var(--color-border-dark);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
  padding: 12px 16px;
  z-index: 60;
  min-width: 280px;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}

.popover-arrow {
  fill: var(--color-bg-surface);
}

/* ---- Badges ---- */
.badge {
  display: inline-flex;
  align-items: center;
  border-radius: var(--radius-sm);
  padding: 2px 8px;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
}

.badge-default  { background: var(--color-border-dark); color: var(--color-text-secondary); }
.badge-success  { background: rgba(139,195,74,0.2);     color: var(--color-accent-success); }
.badge-error    { background: rgba(244,67,54,0.2);      color: var(--color-accent-danger); }
.badge-info     { background: rgba(0,180,216,0.2);      color: var(--color-accent-primary); }
.badge-warning  { background: rgba(255,152,0,0.2);      color: var(--color-accent-warning); }

/* ---- Section header ---- */
.section-header {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-text-label);
  margin-bottom: var(--space-2);
}

/* Legacy .section-title compat */
.section-title {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-text-secondary);
  margin-bottom: var(--space-2);
}

/* ---- Text utilities ---- */
.text-muted   { color: var(--color-text-secondary); }
.text-error   { color: var(--color-accent-danger); font-size: var(--font-size-sm); margin-top: var(--space-1); }
.text-success { color: var(--color-accent-success); font-size: var(--font-size-sm); }

/* Legacy compat */
.error-text   { color: var(--color-accent-danger); font-size: var(--font-size-sm); margin-top: var(--space-1); }
.success-text { color: var(--color-accent-success); font-size: var(--font-size-sm); }

/* ---- Status Dots ---- */
.status-dot {
  display: inline-block;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}
.status-dot-connected    { background: var(--color-status-connected); animation: dot-pulse 2s infinite; }
.status-dot-disconnected { background: var(--color-status-disconnected); }
.status-dot-pending      { background: var(--color-status-pending); animation: dot-pulse 2s infinite; }
.status-dot-idle         { background: var(--color-status-idle); }
/* Orange dot — token connected but not yet logged in */
.status-dot-warning      { background: var(--color-accent-warning); }

/* CN badge shown in header when token is logged in */
.cert-cn-badge {
  font-size: var(--font-size-xs);
  padding: 1px 6px;
  background: rgba(139,195,74,0.15);
  color: var(--color-accent-success);
  border-radius: 4px;
  font-family: var(--font-mono);
  border: 1px solid rgba(139,195,74,0.3);
}

@keyframes dot-pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.35; }
}

/* ---- Scrollbars ---- */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--color-border-dark); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: #3d5070; }

/* ---- Progress Bar ---- */
.progress-track {
  height: 4px;
  background: #1e293b;
  border-radius: 0;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-accent-primary), var(--color-accent-success));
  transition: width var(--transition-slow);
}

/* Encrypt page resizable split divider */
.encrypt-split-divider {
  width: 5px;
  min-width: 5px;
  background: #2d3f5c;
  border-radius: 3px;
  cursor: col-resize;
  transition: background 0.15s;
  flex-shrink: 0;
}
.encrypt-split-divider:hover,
.encrypt-split-divider.dragging {
  background: var(--color-accent-primary);
}
